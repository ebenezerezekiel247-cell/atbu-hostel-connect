{
  "buildCommand": "pnpm --filter @workspace/atbu-hostel-connect run build",
  "outputDirectory": "artifacts/atbu-hostel-connect/dist",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
